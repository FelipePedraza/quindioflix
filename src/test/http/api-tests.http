    "idCategoria": 1,
    "idEmpleadoResponsable": 1,
    "popularidad": 0
}

> {%
    client.test("Crear contenido", function() {
        client.assert(response.status === 201, "Expected 201");
    });
%}

### ========================================
### PERFILES (requiere autenticación)
### ========================================

# Listar perfiles de un usuario
GET {{baseUrl}}/api/usuarios/1/perfiles
Authorization: Bearer {{token}}

> {%
    client.test("Listar perfiles", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}

# Crear perfil
POST {{baseUrl}}/api/usuarios/1/perfiles
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "idUsuario": 1,
    "nombre": "Nuevo Perfil",
    "tipo": "ADULTO"
}

> {%
    client.test("Crear perfil", function() {
        client.assert(response.status === 201, "Expected 201");
    });
%}

### ========================================
### REPRODUCCIONES (requiere autenticación)
### ========================================

# Historial de reproducciones de un perfil
GET {{baseUrl}}/api/perfiles/1/historial
Authorization: Bearer {{token}}

> {%
    client.test("Historial reproducciones", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}

# Registrar reproducción
POST {{baseUrl}}/api/reproducciones
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
    "idPerfil": 1,
    "idContenido": 1,
    "fechaHoraInicio": "2025-01-10T14:00:00",
    "fechaHoraFin": "2025-01-10T15:30:00",
    "dispositivo": "COMPUTADOR",
    "porcentajeAvance": 100
}

> {%
    client.test("Registrar reproducción", function() {
        client.assert(response.status === 201, "Expected 201");
    });
%}

### ========================================
### PRUEBAS DE SEGURIDAD (SIN AUTH)
### ========================================

# Intentar acceder a endpoint protegido sin token
GET {{baseUrl}}/api/usuarios

> {%
    client.test("Sin auth debe permitir GET público", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}

# Intentar crear contenido sin permisos de ADMIN
POST {{baseUrl}}/api/contenido
Content-Type: {{contentType}}

{
    "titulo": "Test sin permisos"
}

> {%
    client.test("Sin permisos debe rechazar", function() {
        client.assert(response.status === 403, "Expected 403");
    });
%}