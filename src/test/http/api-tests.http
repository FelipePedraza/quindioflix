# QuindioFlix - API Tests

@baseUrl = http://localhost:8080
@contentType = application/json

### ========================================
### HEALTH CHECK
### ========================================

GET {{baseUrl}}/api/health

> {%
    client.test("Health check", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
    });
%}

### ========================================
### AUTENTICACIÓN
### ========================================

# Login exitoso (después de ejecutar DML)
POST {{baseUrl}}/api/auth/login
Content-Type: application/x-www-form-urlencoded

email=juan.torres@email.com&password=any

> {%
    client.test("Login exitoso", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.success === true, "Expected success");
        client.assert(response.body.data.token !== null, "Expected token");
    });
    @token = response.body.data.token;
%}

### Login con credenciales inválidas
POST {{baseUrl}}/api/auth/login
Content-Type: application/x-www-form-urlencoded

email=invalid@email.com&password=wrong

> {%
    client.test("Login inválido", function() {
        client.assert(response.status === 401, "Expected 401");
    });
%}

### ========================================
### USUARIOS
### ========================================

# Listar usuarios
GET {{baseUrl}}/api/usuarios

> {%
    client.test("Listar usuarios", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}

### Obtener usuario por ID
GET {{baseUrl}}/api/usuarios/1

> {%
    client.test("Obtener usuario", function() {
        client.assert(response.status === 200, "Expected 200");
        client.assert(response.body.data.id === 1, "Expected id 1");
    });
%}

### Crear usuario
POST {{baseUrl}}/api/usuarios
Content-Type: {{contentType}}

{
    "nombre": "Nuevo Usuario Test",
    "email": "test@newemail.com",
    "telefono": "3001234567",
    "fechaNacimiento": "1995-05-15",
    "ciudad": "Armenia",
    "idPlan": 1,
    "estadoCuenta": "PENDIENTE"
}

> {%
    client.test("Crear usuario", function() {
        client.assert(response.status === 201, "Expected 201");
    });
%}

### Actualizar usuario
PUT {{baseUrl}}/api/usuarios/1
Content-Type: {{contentType}}

{
    "nombre": "Juan Pablo Actualizado",
    "email": "juan.torres@email.com",
    "telefono": "3101234567",
    "fechaNacimiento": "1985-03-15",
    "ciudad": "Armenia",
    "idPlan": 1,
    "estadoCuenta": "ACTIVO"
}

> {%
    client.test("Actualizar usuario", function() {
        client.assert(response.status === 200, "Expected 200");
    });
%}

