Content-Type: {{contentType}}

{
    "titulo": "Nueva Pelicula Test",
    "anioLanzamiento": 2025,
    "duracionMin": 120,
    "sinopsis": "Pelicula de prueba",
    "clasificacionEdad": "+13",
    "fechaCatalogo": "2025-01-01",
